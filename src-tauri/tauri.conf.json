{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Port Scout",
  "version": "0.1.0",
  "identifier": "com.guillerf.portscout",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Port Scout",
        "width": 320,
        "height": 420,
        "minWidth": 300,
        "minHeight": 380,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "fullscreen": false,
        "visible": false,
        "center": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCMUUzMTQ4OEMyNDg0RDkKUldUWmhDU01TREVlZS9YRnhxb2tmc2pub256VC94bXhSQ1FtNW1vd04zK21EYUFTRnJNWEJiQnYK",
      "endpoints": [
        "https://github.com/guillerf/port-scout/releases/latest/download/latest.json"
      ]
    }
  }
}
